interface animal {
    void sound();
}
class dog implements animal {
    public void sound() {
        System.out.println("Dog barks");
    }
    public void bark() {
        System.out.println("Dog barks loudly");
    }
}

public class multilevelinheritence {
    public static void main(String[] args) {
        dog d = new dog();
        d.sound();
        d.bark();
    }
    
}
