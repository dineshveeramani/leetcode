class A {
    void displayA() {
        System.out.println("Class A");
    }
}
class B {
    void displayB() {
        System.out.println("Class B");
    }
}
class C extends A ,B   {
    void displayC() {
        System.out.println("Class C");
    }
}
class D extends A, B, C {
    void displayD() {
        System.out.println("Class D");
    }
}
public class multipleinheritence {
    public static void main(String[] args) {
        D obj = new D();
        obj.displayA();
        obj.displayB();
        obj.displayC();
        obj.displayD();
    }
}
